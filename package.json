{
  "name": "mega-privacy-proxy",
  "version": "1.0.0",
  "private": true,
  "description": "Personal MEGA download privacy proxy (orchestrator + workers + browser client)",
  "scripts": {
    "install:all": "npm install && (cd orchestrator && npm install) && (cd worker && npm install)",
    "start:orchestrator": "node orchestrator/index.js",
    "start:worker": "node worker/index.js",
    "test": "jest --runInBand",
    "test:unit": "jest --runInBand tests/orchestrator.test.js tests/worker.test.js tests/crypto.test.js",
    "test:integration": "jest --runInBand tests/integration.test.js",
    "test:edge": "jest --runInBand --verbose tests/edge-cases.test.js",
    "test:browser": "playwright test tests/browser.test.js",
    "lint": "eslint . --ext .js"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nock": "^13.5.4",
    "@playwright/test": "^1.47.2"
  },
  "engines": { "node": ">=18.0.0" }
}
